---
import BaseLayout from "@layouts/BaseLayout.astro";
import Header from "@components/Header.astro";
import Hero from "@components/Hero.astro";
import HowItWorks from "@components/HowItWorks.astro";
import FeatureOverview from "@components/FeatureOverview.astro";
import MultiDeviceTickets from "@components/MultiDeviceTickets.astro";
import CustomerExperience from "@components/CustomerExperience.astro";
import InventoryManagement from "@components/InventoryManagement.astro";
import WikiKnowledgeBase from "@components/WikiKnowledgeBase.astro";
import TeamPermissions from "@components/TeamPermissions.astro";
import Pricing from "@components/Pricing.astro";
import Differentiators from "@components/Differentiators.astro";
import FAQ from "@components/FAQ.astro";
import CTABanner from "@components/CTABanner.astro";
import Footer from "@components/Footer.astro";
---

<BaseLayout
  title="RepairKeeper — Repair Shop Management Software"
  description="Repair shop management platform — track tickets, generate quotes, manage customers, and run your entire repair business from one place. Free to get started."
>
  <Header />
  <main id="main-content">
    <Hero />
    <HowItWorks />
    <FeatureOverview />
    <MultiDeviceTickets />
    <CustomerExperience />
    <InventoryManagement />
    <WikiKnowledgeBase />
    <TeamPermissions />
    <Pricing />
    <Differentiators />
    <FAQ />
    <CTABanner />
  </main>
  <Footer />
</BaseLayout>
