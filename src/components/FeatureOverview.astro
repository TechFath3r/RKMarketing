---
import { features } from "@data/features";
import Icon from "./Icon.astro";
import SectionHeading from "./SectionHeading.astro";
---

<section id="features" class="py-20 sm:py-28 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionHeading
        title="Everything your repair shop needs"
        subtitle="One platform to manage your entire repair workflow — from intake to collection. Built for phone, electronics, and computer repair shops across the UK."
        badge="Features"
      />
    </div>

    <div class="reveal stagger grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => (
        <div class="card-hover group rounded-2xl border border-slate-200 bg-white p-6 transition-all">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-white">
            <Icon name={feature.icon} size={24} />
          </div>
          <h3 class="mb-2 text-lg font-semibold text-dark">
            {feature.title}
          </h3>
          <p class="text-sm leading-relaxed text-slate-600">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
