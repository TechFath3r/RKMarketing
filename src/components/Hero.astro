---

---

<section class="hero-gradient relative overflow-hidden pt-24 pb-16 sm:pt-32 sm:pb-24 lg:pt-40 lg:pb-32">
  <!-- Decorative blobs -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute -top-24 -right-24 h-96 w-96 rounded-full bg-primary/5 blur-3xl animate-pulse-glow"></div>
    <div class="absolute -bottom-24 -left-24 h-96 w-96 rounded-full bg-accent/5 blur-3xl animate-pulse-glow" style="animation-delay: 1.5s;"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Text Column -->
      <div class="max-w-2xl">
        <!-- Beta Badge -->
        <div class="mb-6 animate-fade-in" style="animation-delay: 0.1s;">
          <span class="inline-flex items-center gap-2 rounded-full border border-primary/20 bg-white/80 px-4 py-1.5 text-sm font-medium text-primary shadow-sm backdrop-blur-sm">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary opacity-75"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full bg-primary"></span>
            </span>
            Now in Beta — All features unlocked for early adopters
          </span>
        </div>

        <!-- Headline -->
        <h1 class="text-4xl font-extrabold tracking-tight text-dark sm:text-5xl lg:text-6xl animate-fade-up" style="animation-delay: 0.2s;">
          Your repair shop,<br />
          <span class="gradient-text">fully under control</span>
        </h1>

        <!-- Subheadline -->
        <p class="mt-6 text-lg leading-relaxed text-slate-600 sm:text-xl animate-fade-up" style="animation-delay: 0.35s;">
          Track tickets, generate quotes, manage customers, and run your entire repair business from one powerful platform. No more spreadsheets, paper tickets, or disconnected tools.
        </p>

        <!-- CTAs -->
        <div class="mt-8 flex flex-wrap items-center gap-4 animate-fade-up" style="animation-delay: 0.5s;">
          <a
            href="https://app.repairkeeper.co.uk/beta"
            class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-base font-semibold text-white shadow-lg shadow-primary/25 transition-all hover:bg-primary-dark hover:shadow-xl hover:shadow-primary/30"
          >
            Get Started Free
            <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
          </a>
          <a
            href="#features"
            class="inline-flex items-center gap-2 rounded-lg border border-slate-300 bg-white px-6 py-3 text-base font-semibold text-slate-700 transition-all hover:border-primary/30 hover:text-primary"
          >
            See Features
          </a>
        </div>

        <!-- Social proof nudge -->
        <p class="mt-6 text-sm text-slate-500 animate-fade-up" style="animation-delay: 0.65s;">
          No credit card required. Set up in under a minute.
        </p>
      </div>

      <!-- Visual Column — App mockup / illustration -->
      <div class="relative hidden lg:block animate-fade-up" style="animation-delay: 0.4s;">
        <div class="relative mx-auto w-full max-w-lg">
          <!-- Main card -->
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-2xl shadow-slate-200/50">
            <!-- Fake header bar -->
            <div class="mb-4 flex items-center gap-2">
              <div class="h-3 w-3 rounded-full bg-red-400"></div>
              <div class="h-3 w-3 rounded-full bg-amber-400"></div>
              <div class="h-3 w-3 rounded-full bg-green-400"></div>
              <span class="ml-2 text-xs text-slate-400">RepairKeeper Dashboard</span>
            </div>
            <!-- Dashboard preview -->
            <div class="space-y-3">
              <div class="flex items-center justify-between rounded-lg bg-slate-50 p-3">
                <div class="flex items-center gap-3">
                  <div class="flex h-8 w-8 items-center justify-center rounded-md bg-primary/10 text-primary">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z" /></svg>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-dark">RK-0042</p>
                    <p class="text-xs text-slate-500">iPhone 15 Pro — Screen Replacement</p>
                  </div>
                </div>
                <span class="rounded-full bg-emerald-100 px-2.5 py-0.5 text-xs font-medium text-emerald-700">Ready</span>
              </div>
              <div class="flex items-center justify-between rounded-lg bg-slate-50 p-3">
                <div class="flex items-center gap-3">
                  <div class="flex h-8 w-8 items-center justify-center rounded-md bg-amber-500/10 text-amber-600">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z" /></svg>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-dark">RK-0043</p>
                    <p class="text-xs text-slate-500">Samsung Galaxy S24 — Battery</p>
                  </div>
                </div>
                <span class="rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-medium text-amber-700">Awaiting Parts</span>
              </div>
              <div class="flex items-center justify-between rounded-lg bg-slate-50 p-3">
                <div class="flex items-center gap-3">
                  <div class="flex h-8 w-8 items-center justify-center rounded-md bg-blue-500/10 text-blue-600">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M2 9a3 3 0 0 1 0 6v2a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-2a3 3 0 0 1 0-6V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2Z" /></svg>
                  </div>
                  <div>
                    <p class="text-sm font-medium text-dark">RK-0044</p>
                    <p class="text-xs text-slate-500">MacBook Air M2 — Keyboard</p>
                  </div>
                </div>
                <span class="rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-700">Diagnosing</span>
              </div>
            </div>
            <!-- Stats row -->
            <div class="mt-4 grid grid-cols-3 gap-3">
              <div class="rounded-lg bg-primary/5 p-3 text-center">
                <p class="text-lg font-bold text-primary">24</p>
                <p class="text-xs text-slate-500">Open Tickets</p>
              </div>
              <div class="rounded-lg bg-success/5 p-3 text-center">
                <p class="text-lg font-bold text-success">8</p>
                <p class="text-xs text-slate-500">Ready</p>
              </div>
              <div class="rounded-lg bg-accent/5 p-3 text-center">
                <p class="text-lg font-bold text-accent">142</p>
                <p class="text-xs text-slate-500">This Month</p>
              </div>
            </div>
          </div>
          <!-- Floating notification card -->
          <div class="absolute -bottom-4 -left-8 rounded-xl border border-slate-200 bg-white p-3 shadow-lg animate-fade-up" style="animation-delay: 0.8s;">
            <div class="flex items-center gap-2">
              <div class="flex h-8 w-8 items-center justify-center rounded-full bg-success/10">
                <svg class="h-4 w-4 text-success" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5" /></svg>
              </div>
              <div>
                <p class="text-xs font-medium text-dark">Parts arrived</p>
                <p class="text-xs text-slate-500">Auto-updated to "In Repair"</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
