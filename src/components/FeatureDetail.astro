---
interface Props {
  title: string;
  subtitle: string;
  badge?: string;
  reverse?: boolean;
  items: { icon: string; title: string; description: string }[];
}

import Icon from "./Icon.astro";

const { title, subtitle, badge, reverse = false, items } = Astro.props;
---

<div class:list={["grid items-center gap-12 lg:grid-cols-2 lg:gap-16", reverse && "lg:[direction:rtl]"]}>
  <!-- Text side -->
  <div class:list={[reverse && "lg:[direction:ltr]"]}>
    {badge && (
      <span class="mb-4 inline-block rounded-full bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary">
        {badge}
      </span>
    )}
    <h3 class="text-2xl font-bold tracking-tight text-dark sm:text-3xl">
      {title}
    </h3>
    <p class="mt-3 text-lg text-slate-600">
      {subtitle}
    </p>
    <ul class="mt-8 space-y-4">
      {items.map((item) => (
        <li class="flex gap-4">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
            <Icon name={item.icon} size={20} />
          </div>
          <div>
            <p class="font-semibold text-dark">{item.title}</p>
            <p class="text-sm text-slate-600">{item.description}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>

  <!-- Visual side (slot) -->
  <div class:list={[reverse && "lg:[direction:ltr]"]}>
    <slot />
  </div>
</div>
