---
import FeatureDetail from "./FeatureDetail.astro";
---

<section class="py-20 sm:py-28 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <FeatureDetail
        title="A seamless experience for your customers"
        subtitle="Give your customers real-time visibility into their repairs — and let them pay online without ever needing to call you."
        badge="Customer Experience"
        reverse={true}
        items={[
          {
            icon: "tracking",
            title: "Live tracking page",
            description: "Every ticket generates a unique link. Customers see real-time status updates, estimated costs, and public notes."
          },
          {
            icon: "credit-card",
            title: "Online payments via Stripe",
            description: "Customers pay invoices directly from their tracking page. Payment status updates automatically — no manual reconciliation."
          },
          {
            icon: "mail",
            title: "Automated email notifications",
            description: "Customers receive emails when their ticket is created and when statuses change. Respects per-customer opt-out preferences."
          },
          {
            icon: "message-square",
            title: "Public enquiry form",
            description: "Embed a branded form on your website. Enquiries land as leads in your dashboard with built-in spam protection."
          }
        ]}
      >
        <!-- Customer tracking mockup -->
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-lg">
          <div class="mb-4 flex items-center gap-2 text-sm text-slate-500">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" /><path d="M2 12h20" /></svg>
            <span>track.repairkeeper.co.uk/RK-0042</span>
          </div>
          <div class="space-y-4">
            <div>
              <p class="text-xs font-medium uppercase tracking-wider text-slate-400">Repair Status</p>
              <div class="mt-2 flex items-center gap-2">
                <span class="relative flex h-3 w-3">
                  <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex h-3 w-3 rounded-full bg-emerald-500"></span>
                </span>
                <span class="text-lg font-bold text-emerald-600">Ready for Collection</span>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div class="rounded-lg bg-slate-50 p-3">
                <p class="text-xs text-slate-500">Device</p>
                <p class="text-sm font-medium text-dark">iPhone 15 Pro</p>
              </div>
              <div class="rounded-lg bg-slate-50 p-3">
                <p class="text-xs text-slate-500">Fault</p>
                <p class="text-sm font-medium text-dark">Screen Replacement</p>
              </div>
            </div>
            <div class="rounded-lg border border-emerald-200 bg-emerald-50 p-3">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-xs text-emerald-600">Invoice #INV-0018</p>
                  <p class="text-lg font-bold text-emerald-700">&pound;89.99</p>
                </div>
                <button class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white">
                  Pay Now
                </button>
              </div>
            </div>
          </div>
        </div>
      </FeatureDetail>
    </div>
  </div>
</section>
