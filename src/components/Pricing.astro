---
import { plans } from "@data/pricing";
import Icon from "./Icon.astro";
import SectionHeading from "./SectionHeading.astro";
---

<section id="pricing" class="py-20 sm:py-28 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <SectionHeading
        title="Simple, transparent pricing"
        subtitle="Start free. Upgrade as your shop grows. No hidden fees."
        badge="Pricing"
      />
    </div>

    <!-- Beta early access banner -->
    <div class="reveal mx-auto mb-12 max-w-2xl rounded-xl border border-primary/20 bg-primary/5 p-5 text-center">
      <div class="mb-2 inline-flex items-center gap-2 rounded-full bg-primary/10 px-3 py-1 text-xs font-semibold text-primary">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary opacity-75"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full bg-primary"></span>
        </span>
        Beta Early Access
      </div>
      <p class="text-sm text-slate-700">
        RepairKeeper is currently in beta. Early adopters get <strong class="text-primary">full access to all features</strong> while we refine the product.
      </p>
      <a
        href="https://app.repairkeeper.co.uk/beta"
        class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-primary transition-colors hover:text-primary-dark"
      >
        Join the beta
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
      </a>
    </div>

    <!-- Billing toggle -->
    <div class="reveal mb-10 flex items-center justify-center">
      <div class="inline-flex items-center gap-1 rounded-lg bg-slate-100 p-1">
        <input type="radio" name="billing" id="monthly" class="peer/monthly sr-only" checked />
        <input type="radio" name="billing" id="yearly" class="peer/yearly sr-only" />
        <label
          for="monthly"
          class="cursor-pointer rounded-md px-4 py-2 text-sm font-medium text-slate-600 transition-all peer-checked/monthly:bg-white peer-checked/monthly:text-dark peer-checked/monthly:shadow-sm"
        >
          Monthly
        </label>
        <label
          for="yearly"
          class="cursor-pointer rounded-md px-4 py-2 text-sm font-medium text-slate-600 transition-all peer-checked/yearly:bg-white peer-checked/yearly:text-dark peer-checked/yearly:shadow-sm"
        >
          Yearly
          <span class="ml-1 rounded-full bg-success/10 px-2 py-0.5 text-xs font-semibold text-success">Save 20%</span>
        </label>
      </div>
    </div>

    <!-- Plans grid — 4 columns on large screens -->
    <div class="reveal stagger grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {plans.map((plan) => (
        <div
          class:list={[
            "card-hover relative flex flex-col rounded-2xl border p-6",
            plan.highlighted
              ? "border-primary bg-white shadow-xl shadow-primary/10 ring-2 ring-primary"
              : "border-slate-200 bg-white",
          ]}
        >
          {plan.highlighted && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="rounded-full bg-primary px-4 py-1 text-xs font-semibold text-white">
                Most Popular
              </span>
            </div>
          )}

          <!-- Plan name -->
          <div class="mb-5">
            <h3 class="text-lg font-bold text-dark">{plan.name}</h3>
            <p class="mt-1 text-sm text-slate-500">{plan.description}</p>
          </div>

          <!-- Price -->
          <div class="mb-5">
            {plan.monthlyPrice === 0 ? (
              <div class="flex items-baseline gap-1">
                <span class="text-3xl font-extrabold text-dark">&pound;0</span>
                <span class="text-sm text-slate-500">/mo</span>
              </div>
            ) : (
              <>
                {/* Monthly price — shown by default, hidden when yearly selected */}
                <div class="monthly-price flex items-baseline gap-1">
                  <span class="text-3xl font-extrabold text-dark">&pound;{plan.monthlyPrice}</span>
                  <span class="text-sm text-slate-500">/mo</span>
                </div>
                {/* Yearly price — hidden by default, shown when yearly selected */}
                <div class="yearly-price hidden">
                  <div class="flex items-baseline gap-1">
                    <span class="text-3xl font-extrabold text-dark">&pound;{Math.round(plan.yearlyPrice / 12)}</span>
                    <span class="text-sm text-slate-500">/mo</span>
                  </div>
                  <p class="mt-0.5 text-xs text-slate-400">&pound;{plan.yearlyPrice} billed yearly</p>
                </div>
              </>
            )}
          </div>

          <!-- CTA -->
          <a
            href={plan.ctaLink}
            class:list={[
              "mb-6 block rounded-lg py-2.5 text-center text-sm font-semibold transition-all",
              plan.highlighted
                ? "bg-primary text-white shadow-lg shadow-primary/25 hover:bg-primary-dark"
                : "border border-slate-300 text-slate-700 hover:border-primary/30 hover:text-primary",
            ]}
          >
            {plan.cta}
          </a>

          <!-- Limits -->
          <div class="mb-5 space-y-2 border-b border-slate-100 pb-5">
            {plan.limits.map((limit) => (
              <div class="flex items-center justify-between text-sm">
                <span class="text-slate-500">{limit.label}</span>
                <span class:list={["font-semibold", limit.value === "Unlimited" ? "text-primary" : "text-dark"]}>
                  {limit.value}
                </span>
              </div>
            ))}
          </div>

          <!-- Features -->
          <ul class="flex-1 space-y-2.5">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-2.5">
                {feature.included ? (
                  <Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" />
                ) : (
                  <Icon name="x" size={16} class="mt-0.5 shrink-0 text-slate-300" />
                )}
                <span class:list={["text-sm", feature.included ? "text-slate-700" : "text-slate-400"]}>
                  {feature.text}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  // Toggle monthly/yearly pricing
  document.addEventListener("DOMContentLoaded", () => {
    const monthly = document.getElementById("monthly");
    const yearly = document.getElementById("yearly");
    if (!monthly || !yearly) return;

    function updatePrices() {
      const isYearly = yearly.checked;
      document.querySelectorAll(".monthly-price").forEach((el) => {
        el.classList.toggle("hidden", isYearly);
      });
      document.querySelectorAll(".yearly-price").forEach((el) => {
        el.classList.toggle("hidden", !isYearly);
      });
    }

    monthly.addEventListener("change", updatePrices);
    yearly.addEventListener("change", updatePrices);
  });
</script>
