---
import FeatureDetail from "./FeatureDetail.astro";
---

<section class="py-20 sm:py-28 bg-slate-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <FeatureDetail
        title="Stock management that works for you"
        subtitle="Track inventory across multiple locations. When you add a part to a ticket, stock is checked and allocated instantly."
        badge="Inventory"
        items={[
          {
            icon: "map-pin",
            title: "Multi-location tracking",
            description: "Manage stock across your main shop, warehouse, or second branch — all from one view."
          },
          {
            icon: "zap",
            title: "Automatic allocation",
            description: "Add a part to a ticket and stock is decremented instantly. When stock arrives, allocate to waiting tickets with one click."
          },
          {
            icon: "alert-triangle",
            title: "Low stock alerts",
            description: "Set minimum stock levels per part per location. Get warned before you run out."
          },
          {
            icon: "search",
            title: "Stock demand view",
            description: "See all parts needed across all open tickets at a glance, with supplier links for easy reordering."
          }
        ]}
      >
        <!-- Inventory mockup -->
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-lg">
          <div class="mb-4 flex items-center justify-between">
            <span class="text-sm font-semibold text-dark">Stock Overview</span>
            <span class="rounded-full bg-primary/10 px-2 py-0.5 text-xs font-medium text-primary">2 locations</span>
          </div>
          <div class="space-y-3">
            <div class="flex items-center justify-between rounded-lg bg-slate-50 p-3">
              <div>
                <p class="text-sm font-medium text-dark">iPhone 15 Pro Screen</p>
                <p class="text-xs text-slate-500">Main Shop</p>
              </div>
              <div class="flex items-center gap-2">
                <span class="rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-medium text-emerald-700">12 in stock</span>
              </div>
            </div>
            <div class="flex items-center justify-between rounded-lg bg-slate-50 p-3">
              <div>
                <p class="text-sm font-medium text-dark">Samsung S24 Battery</p>
                <p class="text-xs text-slate-500">Warehouse</p>
              </div>
              <div class="flex items-center gap-2">
                <span class="rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-700">3 in stock</span>
                <span class="rounded-full bg-red-100 px-2 py-0.5 text-xs font-medium text-red-600">Low</span>
              </div>
            </div>
            <div class="flex items-center justify-between rounded-lg bg-slate-50 p-3">
              <div>
                <p class="text-sm font-medium text-dark">MacBook Air Keyboard</p>
                <p class="text-xs text-slate-500">Main Shop</p>
              </div>
              <div class="flex items-center gap-2">
                <span class="rounded-full bg-red-100 px-2 py-0.5 text-xs font-medium text-red-600">0 in stock</span>
                <span class="text-xs text-blue-600 font-medium">2 needed</span>
              </div>
            </div>
          </div>
          <div class="mt-4 rounded-lg border border-blue-200 bg-blue-50 p-3 text-center">
            <p class="text-xs text-blue-600">3 parts awaiting allocation across 5 tickets</p>
          </div>
        </div>
      </FeatureDetail>
    </div>
  </div>
</section>
