---
import FeatureDetail from "./FeatureDetail.astro";
---

<section class="py-20 sm:py-28 bg-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="reveal">
      <FeatureDetail
        title="Shared repair knowledge at your fingertips"
        subtitle="Build a searchable knowledge base of devices, parts, faults, and repair guides. Contribute to a global database — or keep entries private to your shop."
        badge="Repair Wiki"
        reverse={true}
        items={[
          {
            icon: "wiki",
            title: "Devices, parts, faults & guides",
            description: "Link relationships: which parts fit which devices, which faults affect which devices, which guides solve which faults."
          },
          {
            icon: "globe",
            title: "Global sharing",
            description: "Contribute your repair knowledge to a shared database visible to all RepairKeeper shops — or keep entries private."
          },
          {
            icon: "link",
            title: "Attach resources",
            description: "Link to videos, supplier pages, guides, forums, and documentation directly from wiki entries."
          },
          {
            icon: "search",
            title: "Searchable & linked",
            description: "Quickly find the right guide for any device and fault combination. Import devices in bulk via CSV."
          }
        ]}
      >
        <!-- Wiki mockup -->
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-lg">
          <div class="mb-4 flex items-center justify-between">
            <span class="text-sm font-semibold text-dark">Repair Wiki</span>
            <div class="flex gap-2">
              <span class="rounded-full bg-primary/10 px-2 py-0.5 text-xs font-medium text-primary">146 devices</span>
              <span class="rounded-full bg-accent/10 px-2 py-0.5 text-xs font-medium text-accent">89 guides</span>
            </div>
          </div>
          <div class="mb-3 flex items-center gap-2 rounded-lg bg-slate-50 px-3 py-2">
            <svg class="h-4 w-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" /></svg>
            <span class="text-sm text-slate-400">Search devices, parts, faults...</span>
          </div>
          <div class="space-y-2">
            <div class="rounded-lg border border-slate-200 p-3">
              <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-dark">iPhone 15 Pro</p>
                <span class="rounded bg-emerald-100 px-1.5 py-0.5 text-xs text-emerald-700">Global</span>
              </div>
              <p class="mt-1 text-xs text-slate-500">12 parts &middot; 8 faults &middot; 5 guides</p>
            </div>
            <div class="rounded-lg border border-slate-200 p-3">
              <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-dark">Samsung Galaxy S24</p>
                <span class="rounded bg-emerald-100 px-1.5 py-0.5 text-xs text-emerald-700">Global</span>
              </div>
              <p class="mt-1 text-xs text-slate-500">9 parts &middot; 6 faults &middot; 4 guides</p>
            </div>
            <div class="rounded-lg border border-slate-200 p-3">
              <div class="flex items-center justify-between">
                <p class="text-sm font-medium text-dark">MacBook Air M2</p>
                <span class="rounded bg-slate-100 px-1.5 py-0.5 text-xs text-slate-600">Private</span>
              </div>
              <p class="mt-1 text-xs text-slate-500">7 parts &middot; 4 faults &middot; 3 guides</p>
            </div>
          </div>
        </div>
      </FeatureDetail>
    </div>
  </div>
</section>
