---
interface Props {
  title: string;
  subtitle?: string;
  align?: "center" | "left";
  badge?: string;
}

const { title, subtitle, align = "center", badge } = Astro.props;
---

<div class:list={["mb-12 md:mb-16", align === "center" ? "text-center" : "text-left"]}>
  {badge && (
    <span class="mb-4 inline-block rounded-full bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary">
      {badge}
    </span>
  )}
  <h2 class="text-3xl font-bold tracking-tight text-dark sm:text-4xl lg:text-5xl">
    {title}
  </h2>
  {subtitle && (
    <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
      {subtitle}
    </p>
  )}
</div>
